{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/ks-readymades/browser",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/notion-api/v1/:path*",
      "destination": "/api/notion-proxy/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
